# AgentCare local env template (DO NOT commit real secrets)

# Bolna
BOLNA_API_KEY="bn_xxxxxxxxxxxxxxxxxxxxx"
BOLNA_BASE_URL="https://api.bolna.ai"
BOLNA_AGENT_ID="your-bolna-agent-id"
BOLNA_FROM_NUMBER="+10000000000"

# Mistral (used by local LLM gateway + eval)
MISTRAL_API_KEY="your_mistral_api_key"
MISTRAL_MODEL="mistral-small-latest"

# AgentCare services (local dev)
AGENTCARE_LLM_GATEWAY_URL="http://localhost:8010/v1"
AGENTCARE_MOCK_EHR_URL="http://localhost:8020"

# Cal.com
CAL_API_KEY="cal_live_xxxxxxxxxxxxxxxxxxxxxx"
CAL_EVENT_TYPE_ID="123456"
CAL_TIMEZONE="Asia/Kolkata"

# Email Service (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
AGENTCARE_EMAIL_FROM="contact@yourdomain.com"

# Customer memory persistence
CUSTOMER_STORE_BACKEND="postgres"
CUSTOMER_STORE_PATH="artifacts/customers.json"
PROCESSED_EXECUTIONS_PATH="artifacts/processed_executions.json"

# Supabase / Postgres (for CUSTOMER_STORE_BACKEND=postgres)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxx"
SUPABASE_DB_URL="postgresql://postgres.your-project:your_password@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"